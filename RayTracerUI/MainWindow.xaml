<Window x:Class="RayTracerUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RayTracerUI"
        mc:Ignorable="d"
        Title="Ray Tracer" Height="520" Width="740"
        Background="#1e1e1e">
    <StackPanel Margin="16" >

        <!-- Render output -->
        <Border BorderBrush="#444" BorderThickness="1">
            <Image x:Name="RenderImage"
                   Width="700" Height="394"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                   Stretch="Uniform"/>
        </Border>

        <!-- Progress -->
        <ProgressBar x:Name="ProgressBar"
                     Height="6" Margin="0,10,0,0"
                     Foreground="#56b6c2" Background="#333"
                     BorderThickness="0"/>

        <!-- Status and controls -->
        <DockPanel Margin="0,8,0,0">
            <Button x:Name="SaveButton"
                    DockPanel.Dock="Right"
                    Content="Save PNG"
                    Padding="14,6"
                    IsEnabled="False"
                    Click="SaveButton_Click"
                    Background="#56b6c2" Foreground="White"
                    BorderThickness="0"/>
            <StackPanel>
                <TextBlock x:Name="StatusText"
                           Foreground="#aaa"
                           VerticalAlignment="Center"
                           Text="Starting render..."/>
                <TextBlock x:Name="TimingText"
                           Foreground="#aaa"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </DockPanel>

    </StackPanel>
</Window>
